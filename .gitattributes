# Normalize line endings in the repository to LF.
#
# Without this, files authored on Windows are committed with CRLF and trip
# `git diff --check` (cr-at-eol) on standard CI whitespace gates, including
# the patch/apply pipelines used to import this bundle into other repos.
#
# `text=auto` lets git detect text vs binary; `eol=lf` forces LF in the
# index and checkout for everything classified as text, overriding
# `core.autocrlf` for these matched paths.

* text=auto eol=lf

# Explicit overrides for shell + script formats where LF is required at
# runtime regardless of platform.
*.sh   text eol=lf
*.ps1  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Common binary asset types — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.zip  binary
